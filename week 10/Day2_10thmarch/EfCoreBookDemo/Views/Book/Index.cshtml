@model IEnumerable<EfCoreBookDemo.Models.BookModel>

@{
ViewData["Title"] = "Index";
}

<style>
body{
    font-family:Arial;
}

h1{
    text-align:center;
    margin-bottom:20px;
}

table{
    width:100%;
    border-collapse:collapse;
}

th{
    background-color:#2c3e50;
    color:white;
    padding:12px;
}

td{
    padding:10px;
}

table, th, td{
    border:1px solid #ddd;
}

tr:nth-child(even){
    background-color:#f2f2f2;
}

tr:hover{
    background-color:#ddd;
}

.btn{
    padding:6px 10px;
    text-decoration:none;
    border-radius:4px;
    color:white;
}

.edit{background:#f39c12;}
.details{background:#3498db;}
.delete{background:#e74c3c;}
.add{background:#27ae60;}
</style>

<h1>Book List</h1>

<p>
    <a asp-action="Create" class="btn add">Add New Book</a>
</p>

<table>
    <thead>
        <tr>
            <th>Book Name</th>
            <th>Author</th>
            <th>Price</th>
            <th>Publisher</th>
            <th>Category</th>
            <th>Actions</th>
        </tr>
    </thead>

```
<tbody>

@foreach (var item in Model)
{
    <tr>
        <td>@item.BookName</td>
        <td>@item.Author</td>
        <td>₹@item.Price</td>
        <td>@item.Publisher</td>
        <td>@item.Category</td>

        <td>
            <a asp-action="Edit" asp-route-id="@item.BookId" class="btn edit">Edit</a>
            <a asp-action="Details" asp-route-id="@item.BookId" class="btn details">Details</a>
            <a asp-action="Delete" asp-route-id="@item.BookId" class="btn delete">Delete</a>
        </td>
    </tr>
}

</tbody>
```

</table>
