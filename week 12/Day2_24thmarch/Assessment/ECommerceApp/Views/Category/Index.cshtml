@model IEnumerable<Category>

<h2>📂 Categories</h2>

<a asp-action="Create" class="btn btn-success mb-3">+ Add Category</a>

<table class="table table-striped table-hover shadow">
    <tr>
        <th>Name</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Name</td>
        </tr>
    }
</table>