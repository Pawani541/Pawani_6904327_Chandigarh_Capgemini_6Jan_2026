<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ECommerce</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom Styling -->
    <style>
            body {
                background-color: #f8f9fa;
            }
            .card {
                border-radius: 15px;
            }
    </style>
</head>

<body>

    <!-- 🔥 NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Product" asp-action="Index">🛒 E-Commerce</a>

            <div>
                <a class="btn btn-light me-2" asp-controller="Product" asp-action="Index">Products</a>
                <a class="btn btn-light me-2" asp-controller="Category" asp-action="Index">Categories</a>
                <a class="btn btn-light" asp-controller="Order" asp-action="Index">Orders</a>
            </div>
        </div>
    </nav>

    <!-- 🔥 CONTENT -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- 🔥 FOOTER -->
    <footer class="bg-dark text-white text-center p-3 mt-5">
        <small>© 2026 E-Commerce | Capgemini Assessment</small>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>