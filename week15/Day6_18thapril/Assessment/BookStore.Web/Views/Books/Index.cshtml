@model IEnumerable<BookStore.Application.DTOs.BookDto>
@{
    ViewData["Title"] = "Books";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-book"></i> All Books</h2>
    @if (Context.Session.GetString("UserRole") == "Admin")
    {
        <a asp-action="Create" class="btn btn-success">
            <i class="fas fa-plus"></i> Add New Book
        </a>
    }
</div>

<form asp-action="Index" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="search" value="@ViewBag.Search"
               class="form-control" placeholder="Search by title or ISBN..." />
        <button type="submit" class="btn btn-primary">
            <i class="fas fa-search"></i> Search
        </button>
        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
        {
            <a asp-action="Index" class="btn btn-secondary">Clear</a>
        }
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> No books found.
    </div>
}
else
{
    <div class="row">
        @foreach (var book in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100">
                    @if (!string.IsNullOrEmpty(book.ImageUrl))
                    {
                        <img src="@book.ImageUrl" class="card-img-top" style="height:200px;object-fit:cover;" alt="@book.Title" />
                    }
                    else
                    {
                        <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height:200px;">
                            <i class="fas fa-book fa-4x text-white"></i>
                        </div>
                    }
                    <div class="card-body">
                        <h5 class="card-title">@book.Title</h5>
                        <p class="card-text text-muted">
                            <small><i class="fas fa-user"></i> @book.AuthorName</small><br />
                            <small><i class="fas fa-tag"></i> @book.CategoryName</small><br />
                            <small><i class="fas fa-barcode"></i> @book.ISBN</small>
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-5 fw-bold text-success">Rs. @book.Price</span>
                            <span class="badge @(book.Stock > 0 ? "bg-success" : "bg-danger")">
                                @(book.Stock > 0 ? $"In Stock ({book.Stock})" : "Out of Stock")
                            </span>
                        </div>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@book.BookId"
                           class="btn btn-outline-primary btn-sm flex-fill">
                            <i class="fas fa-eye"></i> Details
                        </a>
                        @if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <a asp-action="Edit" asp-route-id="@book.BookId"
                               class="btn btn-outline-warning btn-sm">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-action="Delete" asp-route-id="@book.BookId"
                               class="btn btn-outline-danger btn-sm">
                                <i class="fas fa-trash"></i>
                            </a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
