@model BookStore.Application.DTOs.OrderCreateDto
@{
    ViewData["Title"] = "Checkout";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <h3 class="mb-4"><i class="fas fa-shopping-cart"></i> Place Order</h3>
            <form asp-action="Checkout" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label class="form-label">User ID</label>
                    <input name="UserId" type="number" class="form-control"
                           value="@Context.Session.GetInt32("UserId")" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Book ID</label>
                    <input name="Items[0].BookId" type="number" class="form-control" placeholder="Enter Book ID" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Quantity</label>
                    <input name="Items[0].Qty" type="number" class="form-control" value="1" min="1" max="100" />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-check"></i> Place Order
                    </button>
                    <a asp-controller="Books" asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
