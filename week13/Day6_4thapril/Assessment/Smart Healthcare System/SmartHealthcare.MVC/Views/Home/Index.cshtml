@{
    ViewData["Title"] = "Home";
}
<div class="p-5 mb-4 bg-primary text-white rounded-3">
    <div class="container-fluid py-3">
        <h1 class="display-5 fw-bold">🏥 Smart Hospital Management System</h1>
        <p class="col-md-8 fs-4">Your health is our priority. Book appointments, view doctors, and manage your health records online.</p>
        <a class="btn btn-light btn-lg me-2" href="/Doctor">Browse Doctors</a>
        <a class="btn btn-outline-light btn-lg" href="/Account/Register">Register Now</a>
    </div>
</div>

<div class="row mt-4">
    <div class="col-md-4">
        <div class="card text-center p-4">
            <h1>👨‍⚕️</h1>
            <h4>Expert Doctors</h4>
            <p>Specialists across Cardiology, Neurology, Orthopedics and more.</p>
            <a href="/Doctor" class="btn btn-primary">View Doctors</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-4">
            <h1>📅</h1>
            <h4>Easy Appointments</h4>
            <p>Book appointments with your preferred doctor in just a few clicks.</p>
            <a href="/Appointment/Book" class="btn btn-success">Book Now</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center p-4">
            <h1>💊</h1>
            <h4>Medical Records</h4>
            <p>Access prescriptions, bills and your complete medical history.</p>
            <div id="medicalRecordsContent">
                <a href="/Account/Login" class="btn btn-info text-white" id="loginBtn">Login to View</a>
            </div>
        </div>
    </div>
</div>

<!-- Bills Section -->
<div id="billsSection" style="display:none;" class="mt-5">
    <h3 class="mb-3">💳 My Medical Bills</h3>
    <div class="mb-3">
        <button class="btn btn-outline-danger me-2" onclick="filterHomeBills('Unpaid')">🔴 Unpaid</button>
        <button class="btn btn-outline-success me-2" onclick="filterHomeBills('Paid')">🟢 Paid</button>
        <button class="btn btn-outline-secondary" onclick="filterHomeBills('All')">📋 All</button>
    </div>
    <div id="homeBillsList">
        <div class="text-center"><div class="spinner-border text-warning"></div></div>
    </div>
</div>

<script>
    let homeBills = [];

    const userId = sessionStorage.getItem('userId');
    const userName = sessionStorage.getItem('userFullName');
    const userRole = sessionStorage.getItem('userRole');

    if (userId && userRole === 'Patient') {
        // Update Medical Records card
        document.getElementById('medicalRecordsContent').innerHTML = `
            <p class="text-success fw-bold">👤 ${userName}</p>
            <a href="/Patient" class="btn btn-info text-white">View Full Records</a>`;

        // Show bills section
        document.getElementById('billsSection').style.display = 'block';

        fetch(`https://localhost:7100/api/Bills/patient/${userId}`)
            .then(r => r.json())
            .then(bills => {
                homeBills = bills;
                renderHomeBills(bills);
            })
            .catch(() => {
                document.getElementById('homeBillsList').innerHTML = '<div class="alert alert-danger">Could not load bills. Make sure the API is running.</div>';
            });
    } else if (userId && userRole === 'Doctor') {
        document.getElementById('medicalRecordsContent').innerHTML = `
            <p class="text-success fw-bold">👨‍⚕️ ${userName}</p>
            <a href="/Doctor" class="btn btn-info text-white">View Patient Bills</a>`;
    }

    function filterHomeBills(status) {
        const filtered = status === 'All' ? homeBills : homeBills.filter(b => b.paymentStatus === status);
        renderHomeBills(filtered);
    }

    function renderHomeBills(bills) {
        const cont = document.getElementById('homeBillsList');
        if (bills.length === 0) {
            cont.innerHTML = '<div class="alert alert-info">No bills found.</div>';
            return;
        }
        let html = `<table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Bill ID</th>
                    <th>Appointment ID</th>
                    <th>Doctor Fee</th>
                    <th>Medicine Charges</th>
                    <th>Total Amount</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead><tbody>`;
        bills.forEach(b => {
            const total = (parseFloat(b.consultationFee) + parseFloat(b.medicineCharges)).toFixed(2);
            const badge = b.paymentStatus === 'Paid' ? 'success' : 'danger';
            html += `<tr>
                <td>${b.billId}</td>
                <td>${b.appointmentId}</td>
                <td>₹${b.consultationFee}</td>
                <td>₹${b.medicineCharges}</td>
                <td><strong>₹${total}</strong></td>
                <td><span class="badge bg-${badge}">${b.paymentStatus}</span></td>
                <td>${b.paymentStatus === 'Unpaid'
                    ? `<button class="btn btn-sm btn-danger fw-bold" onclick="payBill(${b.billId})">💳 Pay Bill</button>`
                    : '<span class="text-success fw-bold">✔ Paid</span>'}</td>
            </tr>`;
        });
        html += '</tbody></table>';
        cont.innerHTML = html;
    }

    function payBill(billId) {
        if (!confirm('Confirm payment for this bill?')) return;
        fetch(`https://localhost:7100/api/Bills/${billId}/pay`, { method: 'PUT' })
            .then(r => r.json())
            .then(() => {
                homeBills = homeBills.map(b => b.billId === billId ? { ...b, paymentStatus: 'Paid' } : b);
                renderHomeBills(homeBills);
                alert('✅ Payment successful!');
            })
            .catch(() => alert('❌ Payment failed. Please try again.'));
    }
</script>
