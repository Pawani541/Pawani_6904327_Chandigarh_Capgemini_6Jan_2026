<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Smart Healthcare</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { font-weight: bold; font-size: 1.4rem; }
        .card { border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand" href="/">🏥 Smart Healthcare</a>
            <div class="navbar-nav ms-auto" id="navLinks">
                <a class="nav-link text-white" href="/">Home</a>
                <a class="nav-link text-white" href="/Doctor">Doctors</a>
                <a class="nav-link text-white" href="/Appointment">Appointments</a>
            </div>
        </div>
    </nav>
    <div class="container mt-4">
        @RenderBody()
    </div>
    <footer class="text-center mt-5 py-3 bg-primary text-white">
        <p class="mb-0">© 2026 Smart Healthcare System | Capgemini Assessment</p>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const userId = sessionStorage.getItem('userId');
        const userName = sessionStorage.getItem('userFullName');
        const userRole = sessionStorage.getItem('userRole');
        const nav = document.getElementById('navLinks');

        if (userId && userName) {
            if (userRole === 'Doctor') {
                nav.innerHTML += `<a class="nav-link text-white" href="/Doctor">👨‍⚕️ My Dashboard</a>`;
            } else if (userRole === 'Patient') {
                nav.innerHTML += `<a class="nav-link text-white" href="/Appointment/Book">📅 Book Appointment</a>`;
                nav.innerHTML += `<a class="nav-link text-white" href="/Patient">🏥 My Dashboard</a>`;
            } else {
                nav.innerHTML += `<a class="nav-link text-white" href="/Account/Login">Login</a>`;
                nav.innerHTML += `<a class="nav-link text-white" href="/Account/Register">Register</a>`;
            }
            nav.innerHTML += `<span class="nav-link text-white fw-bold"><span class="badge bg-warning text-dark">👤 ${userName} (${userRole})</span></span>`;
            nav.innerHTML += `<a class="nav-link text-white" href="#" onclick="sessionStorage.clear(); window.location.href='/';">🚪 Logout</a>`;
        } else {
            nav.innerHTML += `<a class="nav-link text-white" href="/Account/Login">Login</a>`;
            nav.innerHTML += `<a class="nav-link text-white" href="/Account/Register">Register</a>`;
        }
    </script>
</body>
</html>
