@model List<SmartHealthcare.MVC.Models.AppointmentViewModel>
@{ ViewData["Title"] = "Appointments"; }
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>
            @if (ViewBag.Role == "Doctor")
            { <span>Patient Appointments Assigned to Me</span> }
            else if (ViewBag.Role == "Patient")
            { <span>My Appointments</span> }
            else
            { <span>All Appointments</span> }
        </h3>
        <a asp-action="Create" class="btn btn-primary">+ Book Appointment</a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-warning">@ViewBag.Error</div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">No appointments found.</div>
    }
    else
    {
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Date & Time</th>
                    <th>Doctor</th>
                    <th>Patient</th>
                    <th>Status</th>
                    <th>Notes</th>
                    @if (ViewBag.Role == "Doctor" || ViewBag.Role == "Admin")
                    {
                        <th>Action</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var a in Model)
                {
                <tr>
                    <td>@a.AppointmentDate.ToString("dd MMM yyyy HH:mm")</td>
                    <td>@a.DoctorName</td>
                    <td>@a.PatientName</td>
                    <td>
                        @{
                            var badgeClass = a.Status switch
                            {
                                "Scheduled"  => "bg-primary",
                                "Accepted"   => "bg-success",
                                "Rejected"   => "bg-danger",
                                "Completed"  => "bg-success",
                                "Cancelled"  => "bg-danger",
                                "InProgress" => "bg-warning text-dark",
                                _            => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeClass">@a.Status</span>
                    </td>
                    <td>@a.Notes</td>
                    @if (ViewBag.Role == "Doctor")
                    {
                        <td>
                            @if (a.Status == "Scheduled" || a.Status == "Pending")
                            {
                                <form asp-action="UpdateStatus" asp-route-id="@a.Id" method="post" class="d-inline">
                                    <input type="hidden" name="status" value="Accepted" />
                                    <button type="submit" class="btn btn-sm btn-success me-1">✔ Accept</button>
                                </form>
                                <form asp-action="UpdateStatus" asp-route-id="@a.Id" method="post" class="d-inline">
                                    <input type="hidden" name="status" value="Rejected" />
                                    <button type="submit" class="btn btn-sm btn-danger">✘ Reject</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">No action needed</span>
                            }
                        </td>
                    }
                    else if (ViewBag.Role == "Admin")
                    {
                        <td>
                            <a asp-action="UpdateStatus" asp-route-id="@a.Id"
                               class="btn btn-sm btn-outline-warning">Update Status</a>
                        </td>
                    }
                </tr>
                }
            </tbody>
        </table>
    }
</div>
