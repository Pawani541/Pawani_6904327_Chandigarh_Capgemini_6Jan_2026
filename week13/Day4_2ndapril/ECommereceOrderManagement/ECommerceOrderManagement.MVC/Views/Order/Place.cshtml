@{
    ViewData["Title"] = "Place Order";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var productId = ViewBag.ProductId?.ToString()
                 ?? Context.Request.RouteValues["productId"]?.ToString()
                 ?? Context.Request.Query["productId"].ToString();
}

<div class="row justify-content-center">
<div class="col-md-5">
<div class="card p-4">
    <h3 class="text-center mb-4"><i class="fas fa-shopping-cart me-2"></i>Place Order</h3>
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">@ViewBag.Error</div>
    }
    <form method="post" action="/Order/ConfirmOrder">
        <input type="hidden" name="ProductId" value="@productId" />
        <div class="mb-3">
            <label class="form-label fw-bold">Quantity</label>
            <input name="Quantity" type="number" min="1" value="1" class="form-control"/>
        </div>
        <p class="text-muted text-center">Ordering Product ID: <strong>@productId</strong></p>
        <button type="submit" class="btn btn-primary w-100">
            <i class="fas fa-check me-2"></i>Confirm Order
        </button>
        <a href="/" class="btn btn-outline-secondary w-100 mt-2">Cancel</a>
    </form>
</div>
</div>
</div>
