@model List<ECommerceOrderManagement.MVC.Models.ProductViewModel>
@{ ViewData["Title"] = "Products"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<h2 class="mb-4"><i class="fas fa-store me-2"></i>Our Products</h2>
<div class="row g-4">
@foreach (var p in Model)
{
    <div class="col-md-4">
        <div class="card h-100 p-3">
            <div class="card-body">
                <h5 class="card-title fw-bold">@p.Name</h5>
                <p class="text-muted">@p.Description</p>
                <h4 class="text-primary fw-bold">&#8377;@p.Price.ToString("N0")</h4>
                <p class="text-success"><i class="fas fa-cubes me-1"></i>Stock: @p.StockQuantity</p>
            </div>
            <div class="card-footer bg-transparent d-flex gap-2">
                @if (!User.IsInRole("Admin"))
                {
                    <a href="/Order/Place?productId=@p.Id" class="btn btn-primary flex-fill">
                        <i class="fas fa-shopping-cart me-1"></i>Order Now
                    </a>
                }
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Product/Delete/@p.Id" class="btn btn-danger"
                       onclick="return confirm('Delete this product?')">
                        <i class="fas fa-trash"></i>
                    </a>
                }
            </div>
        </div>
    </div>
}
</div>

