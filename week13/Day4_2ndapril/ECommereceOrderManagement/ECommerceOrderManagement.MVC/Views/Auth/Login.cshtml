@model ECommerceOrderManagement.MVC.Models.LoginViewModel
@{ ViewData["Title"] = "Login"; Layout = "~/Views/Shared/_Layout.cshtml"; }

<div class="row justify-content-center">
<div class="col-md-5">
<div class="card p-4">
    <h3 class="text-center mb-4"><i class="fas fa-sign-in-alt me-2"></i>Login</h3>
    @if (ViewBag.Error != null) { <div class="alert alert-danger">@ViewBag.Error</div> }
    <form method="post">
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input asp-for="Email" class="form-control" placeholder="email@example.com"/>
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Password"/>
        </div>
        <button type="submit" class="btn btn-primary w-100">Login</button>
        <p class="text-center mt-3">No account? <a href="/Auth/Register">Register</a></p>
    </form>
</div>
</div>
</div>
